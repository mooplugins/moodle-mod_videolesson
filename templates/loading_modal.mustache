{{!
    @template mod_videolesson/loading_modal

    Full-page loading overlay used during library AJAX operations.
}}

<div id="videolesson-modal-loading" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
     background: rgba(0,0,0,0.5); z-index: 9999; justify-content: center; align-items: center;">
    <div class="spinner-border text-light" role="status">
        <span class="d-none">Loading...</span>
    </div>
</div>